FROM mcr.microsoft.com/dotnet/sdk:10.0 AS build
WORKDIR /src

COPY . .
RUN dotnet restore HealthManager.sln
RUN dotnet publish src/HealthManager.Worker/HealthManager.Worker.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/runtime:10.0
WORKDIR /app

RUN apt-get update && apt-get install -y libgssapi-krb5-2 --no-install-recommends && rm -rf /var/lib/apt/lists/*

COPY --from=build /app/publish .

USER app
ENTRYPOINT ["dotnet", "HealthManager.Worker.dll"]
